<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>To-Do List</title>
    <style>
        body {
            font-family: Arial, sans-serif;
            max-width: 600px;
            margin: 2rem auto;
            padding: 1rem;
            background-color: #f9f9f9;
        }
        .container {
            background: white;
            padding: 2rem;
            border-radius: 8px;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }
        .task-input {
            width: calc(100% - 110px);
            padding: 10px;
            margin-right: 10px;
            border: 1px solid #ccc;
            border-radius: 4px;
        }
        .btn {
            padding: 10px 15px;
            border: none;
            border-radius: 4px;
            cursor: pointer;
        }
        .btn-add { background-color: #28a745; color: white; }
        .btn-complete { background-color: #ffc107; color: black; }
        .btn-delete { background-color: #dc3545; color: white; }
        
        .task-list { list-style: none; padding: 0; margin-top: 20px; }
        .task-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 10px;
            border-bottom: 1px solid #eee;
        }
        .completed span {
            text-decoration: line-through;
            color: #888;
        }
        .actions form {
            display: inline;
        }
    </style>
</head>
<body>

    <div class="container">
        <h2>Lista de Tarefas</h2>

        <form action="/add" method="POST">
            <input type="text" name="taskText" class="task-input" placeholder="O que precisa ser feito?" required autocomplete="off">
            <button type="submit" class="btn btn-add">Adicionar</button>
        </form>

        <ul class="task-list">
            <% if (tasks.length === 0) { %>
                <p style="text-align: center; color: #666;">Nenhuma tarefa cadastrada.</p>
            <% } else { %>
                <% tasks.forEach(task => { %>
                    <li class="task-item <%= task.completed ? 'completed' : '' %>">
                        <span><%= task.text %></span>
                        
                        <div class="actions">
                            <form action="/complete/<%= task.id %>" method="POST">
                                <button type="submit" class="btn btn-complete">
                                    <%= task.completed ? 'Desfazer' : '✓' %>
                                </button>
                            </form>
                            
                            <form action="/delete/<%= task.id %>" method="POST">
                                <button type="submit" class="btn btn-delete">X</button>
                            </form>
                        </div>
                    </li>
                <% }) %>
            <% } %>
        </ul>
    </div>

</body>
</html>
